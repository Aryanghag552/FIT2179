{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Distribution of Bleaching Severity",
        "subtitle": "Proportion of survey observations by severity category across all years.",
        "fontSize": 16,
        "font": "Playfair Display",
        "subtitleFont": "Lato",
        "subtitleFontSize": 12,
        "subtitleColor": "#7f8c8d",
        "anchor": "start"
    },
    "width": 350,
    "height": 350,
    "data": {
        "url": "gbr_bleaching.csv"
    },
    "transform": [
        {"filter": "datum.Percent_Bleaching != 'nd'"},
        {
            "calculate": "datum.Percent_Bleaching <= 10 ? 'Low (0-10%)' : datum.Percent_Bleaching <= 30 ? 'Moderate (10-30%)' : datum.Percent_Bleaching <= 60 ? 'High (30-60%)' : 'Severe (60-100%)'",
            "as": "Severity"
        }
    ],
    "mark": {"type": "arc", "innerRadius": 70},
    "encoding": {
        "theta": {
            "aggregate": "count",
            "type": "quantitative"
        },
        "color": {
            "field": "Severity",
            "type": "nominal",
            "title": "Severity Level",
            "scale": {
                "domain": ["Low (0-10%)", "Moderate (10-30%)", "High (30-60%)", "Severe (60-100%)"],
                "range": ["#f9e79f", "#f5b041", "#e74c3c", "#922b21"]
            },
            "sort": ["Low (0-10%)", "Moderate (10-30%)", "High (30-60%)", "Severe (60-100%)"]
        },
        "tooltip": [
            {"field": "Severity", "type": "nominal", "title": "Severity"},
            {"aggregate": "count", "type": "quantitative", "title": "Observations"}
        ]
    },
    "config": {
        "font": "Lato",
        "view": {"stroke": null},
        "background": "#fafbfc"
    }
}
