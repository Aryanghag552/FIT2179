{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Average Bleaching by Region Over Time",
        "subtitle": "Click a region in the legend to highlight it.",
        "fontSize": 16,
        "font": "Playfair Display",
        "subtitleFont": "Lato",
        "subtitleFontSize": 12,
        "subtitleColor": "#7f8c8d",
        "anchor": "start"
    },
    "width": 400,
    "height": 300,
    "data": {
        "url": "gbr_bleaching.csv"
    },
    "transform": [
        {"filter": "datum.Percent_Bleaching != 'nd'"}
    ],
    "params": [
        {
            "name": "region_highlight",
            "select": {"type": "point", "fields": ["GBR_Region"]},
            "bind": "legend"
        }
    ],
    "mark": {"type": "area", "opacity": 0.7},
    "encoding": {
        "x": {
            "field": "Date_Year",
            "type": "ordinal",
            "title": "Year",
            "axis": {"labelAngle": -45}
        },
        "y": {
            "aggregate": "mean",
            "field": "Percent_Bleaching",
            "type": "quantitative",
            "title": "Avg Bleaching %",
            "stack": "zero"
        },
        "color": {
            "field": "GBR_Region",
            "type": "nominal",
            "title": "GBR Region",
            "scale": {
                "domain": ["Northern", "Central", "Southern"],
                "range": ["#e74c3c", "#f39c12", "#2980b9"]
            },
            "legend": {"orient": "bottom", "direction": "horizontal"}
        },
        "opacity": {
            "condition": {"param": "region_highlight", "value": 0.8},
            "value": 0.15
        },
        "tooltip": [
            {"field": "GBR_Region", "type": "nominal", "title": "Region"},
            {"field": "Date_Year", "type": "ordinal", "title": "Year"},
            {"aggregate": "mean", "field": "Percent_Bleaching", "type": "quantitative", "title": "Avg Bleaching %", "format": ".1f"}
        ]
    },
    "config": {
        "font": "Lato",
        "view": {"stroke": null},
        "background": "#fafbfc"
    }
}
